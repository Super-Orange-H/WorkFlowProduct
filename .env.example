N8N_GENERATOR_MIN_INTERVAL_MS = "4000"

# free trial credits
INITIAL_CREDITS_ENABLED = "true"
INITIAL_CREDITS_AMOUNT = "6"
INITIAL_CREDITS_VALID_DAYS = "30"
