# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "WorkflowPilot AI"
NEXT_PUBLIC_APP_DESCRIPTION = "Turn natural language automation ideas into import-ready n8n workflow JSON."
NEXT_PUBLIC_APP_LOGO = "/logo-workflowpilot.png"
NEXT_PUBLIC_APP_FAVICON = "/favicon-workflowpilot.ico"
NEXT_PUBLIC_APP_PREVIEW_IMAGE = "/preview.png"
